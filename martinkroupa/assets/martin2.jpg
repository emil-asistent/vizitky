		width: 50% !important;
	} */
	#pece-servis .e-con-inner {
		padding-top: 0px !important;
	}
	.my-sluzby .elementor-widget-text-editor ul {
		margin-top: 40px !important;
	}
}

@media (max-width: 549px)
{
	.kraj-vyber-box {
		display: none;
	}
	.show-poradci-link {
		display: block;
		text-align: center;
		background-color: #99C6C3;
		font-weight: bold;
		color: #ffffff;
		margin: 20px auto;
		padding: 5px 20px;
		width: fit-content;
	}
	.show-poradci-link:hover {
		color: #ffffff;
	}
	.kraj-select-headline {
