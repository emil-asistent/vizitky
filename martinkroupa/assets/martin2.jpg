			body, #content {
	overflow-x: hidden !important;
}

.my-header-desktop {
	display: block !important;
}
.my-header-mobile {
	display: none !important;
}

.my-ikony-1 .e-child:nth-child(1) {
	background-color: #192d4d !important;
	padding: 120px 0px !important;
}

.my-ikony-1 .e-child:nth-child(2) {
	background-color: #0d1f3a !important;
	padding: 120px 0px !important;
}

.my-ikony-2 .e-child:nth-child(1) {
	background-color: #7caaa7 !important;
	padding: 120px 0px !important;
}

.my-ikony-2 .e-child:nth-child(2) {
	background-color: #99c6c3 !important;
	padding: 120px 0px !important;
}

.nav-menu .menu-item a {
	font-size: 1.5em !important;
	font-weight: bold !important;
}

.nav-menu .menu-item a:hover {
	color: #ffffff !important;
}

.nav-menu .current-menu-item a {
	text-decoration: underline !important;
}

#sidebar-footer {
	background-color: #192d4d !important;
}

#sidebar-footer .wp-container-1 .wp-block-button__link {
	color: #0d1f3a !important;
}

#sidebar-footer .wp-container-2 .wp-block-button__link {
	background-color: #ffffff !important;
	color: #0d1f3a !important;
}

#sidebar-footer .wp-container-3 .wp-block-button__link {
	background-color: #0d1f3a !important;
	color: #ffffff !important;
}

footer {
	background-color: #0d1f3a !important;
}

footer img {
	width: 120px !important;
}

footer .sydney-svg-icon {
	width: 40px !important;
}

.elementor-widget-text-editor ul {
	margin-top: 0 !important;
	padding-top: 0 !important;
}

#sb_instagram {
	display: none !important;
}

.site-info {
	padding-top: 40px !important;
	padding-bottom: 40px !important;
}

.my-head-foto img {
	width: 100% !important;
}

@media (orientation: portrait) {
	.my-head-foto-portrait {
		display: block;
	}
	.my-head-foto {
		display: none;
	}
}

@media (min-width: 992px)
{
	.container-fluid 
	{
		padding-right: 0px !important;
		padding-left: 0px !important;
	}
}

@media (max-width: 767px)
{
	.my-header-desktop {
		display: none !important;
	}
	.my-header-mobile {
		display: block !important;
	}
	.my-home-about-image {
		margin-top: 100px !important;
	}
	.elementor-widget-text-editor {
		text-align: center !important
	}
	footer {
		padding-bottom: 40px !important
	}
	.elementor-social-icons-wrapper {
		text-align: center !important;
	}
	h2 {
		text-align: center !important;
	}
	.elementor-button-wrapper {
		text-align: center !important;
	}
	ul, li {
		text-align: left !important;
	}
